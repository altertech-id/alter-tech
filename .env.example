# ── Supabase ────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API
# PUBLIC_* vars are exposed to the browser (safe: anon key respects RLS).
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER prefix with PUBLIC_ and never commit it.
# Used for the public tracking endpoint + storage admin + seeding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Site ────────────────────────────────────────────────────
# Public base URL, used for canonical tags / redirects.
PUBLIC_SITE_URL=https://altertech.id
